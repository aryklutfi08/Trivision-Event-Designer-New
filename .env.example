# PostgreSQL (Neon recommended). DATABASE_URL = pooled connection used by the app;
# DATABASE_URL_UNPOOLED = direct/non-pooled connection used for migrations.
# Neon's Vercel integration sets both automatically. If you only have one URL,
# set both vars to that same direct connection string.
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"
DATABASE_URL_UNPOOLED="postgresql://user:password@host/dbname?sslmode=require"

# Secret used to sign session cookies. Generate one, e.g.:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
SESSION_SECRET="change-me-to-a-long-random-string"

# Seed admin account (created/synced on deploy + `npm run db:seed`).
# The seed updates this account's password to match these values on every run.
ADMIN_USERNAME="Trivision"
ADMIN_PASSWORD="Trivision4000!"
ADMIN_DISPLAY_NAME="TriVision Admin"

# Local dev port (optional)
PORT=3400
