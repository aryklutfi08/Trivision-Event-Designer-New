{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npx prisma generate && npx prisma migrate deploy && node prisma/seed.js",
  "functions": {
    "api/index.js": {
      "includeFiles": "public/**",
      "maxDuration": 300
    }
  },
  "rewrites": [{ "source": "/(.*)", "destination": "/api/index" }]
}
