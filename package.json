{
  "name": "trivision-event-designer",
  "version": "1.0.0",
  "private": true,
  "description": "TriVision Event Designer with admin/guest login wall",
  "scripts": {
    "dev": "nodemon server.js",
    "start": "node server.js",
    "test": "node qa/seat-count.mjs",
    "postinstall": "prisma generate",
    "db:deploy": "prisma migrate deploy",
    "db:push": "prisma db push",
    "db:seed": "node prisma/seed.js",
    "vercel-build": "prisma generate && prisma migrate deploy && node prisma/seed.js"
  },
  "prisma": {
    "seed": "node prisma/seed.js"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "bcryptjs": "^2.4.3",
    "cookie": "^0.6.0",
    "dotenv": "^16.4.5",
    "express": "^4.21.2",
    "jsonwebtoken": "^9.0.2"
  },
  "devDependencies": {
    "nodemon": "^3.1.7",
    "prisma": "^5.22.0"
  }
}
